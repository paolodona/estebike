---
import JsonLd from './JsonLd.astro';

export interface Props {
  title: string;
  description: string;
  image?: string;
  datePublished: string;
  author: string;
  url: string;
}

const { title, description, image, datePublished, author, url } = Astro.props;
const siteUrl = 'https://estebike.it';

const data: Record<string, unknown> = {
  '@context': 'https://schema.org',
  '@type': 'BlogPosting',
  headline: title,
  description,
  datePublished,
  url,
  mainEntityOfPage: { '@type': 'WebPage', '@id': url },
  author: {
    '@type': 'Person',
    name: author,
  },
  publisher: {
    '@type': 'Organization',
    name: 'EsteBike',
    logo: {
      '@type': 'ImageObject',
      url: `${siteUrl}/images/estebike-icon.svg`,
    },
  },
};

if (image) {
  data.image = image.startsWith('http') ? image : `${siteUrl}${image}`;
}
---

<JsonLd data={data} />
