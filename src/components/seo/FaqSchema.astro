---
import JsonLd from './JsonLd.astro';

export interface Props {
  items: { question: string; answer: string }[];
}

const { items } = Astro.props;

const data = {
  '@context': 'https://schema.org',
  '@type': 'FAQPage',
  mainEntity: items.map((item) => ({
    '@type': 'Question',
    name: item.question,
    acceptedAnswer: {
      '@type': 'Answer',
      text: item.answer,
    },
  })),
};
---
<JsonLd data={data} />
