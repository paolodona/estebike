---
export interface Option {
  value: string;
  label: string;
  disabled?: boolean;
}

export interface Props {
  name: string;
  id?: string;
  label: string;
  options: Option[];
  placeholder?: string;
  required?: boolean;
  disabled?: boolean;
  value?: string;
  error?: string;
  hint?: string;
  class?: string;
}

const {
  name,
  id = name,
  label,
  options,
  placeholder = 'Seleziona...',
  required = false,
  disabled = false,
  value = '',
  error,
  hint,
  class: className = '',
} = Astro.props;

const inputId = `select-${id}`;
const errorId = error ? `${inputId}-error` : undefined;
const hintId = hint ? `${inputId}-hint` : undefined;
const describedBy = [errorId, hintId].filter(Boolean).join(' ') || undefined;
---

<div class:list={['input-group', error && 'input-group--error', className]}>
  <label for={inputId} class="input-label">
    {label}
    {
      required && (
        <span class="input-required" aria-hidden="true">
          *
        </span>
      )
    }
  </label>

  {
    hint && (
      <p id={hintId} class="input-hint">
        {hint}
      </p>
    )
  }

  <div class="select-wrapper">
    <select
      id={inputId}
      name={name}
      required={required}
      disabled={disabled}
      aria-invalid={error ? 'true' : undefined}
      aria-describedby={describedBy}
      class="select-field"
    >
      <option value="" disabled selected={!value}>{placeholder}</option>
      {
        options.map((option) => (
          <option
            value={option.value}
            disabled={option.disabled}
            selected={value === option.value}
          >
            {option.label}
          </option>
        ))
      }
    </select>
    <svg
      class="select-icon"
      xmlns="http://www.w3.org/2000/svg"
      width="20"
      height="20"
      viewBox="0 0 24 24"
      fill="none"
      stroke="currentColor"
      stroke-width="2"
      stroke-linecap="round"
      stroke-linejoin="round"
    >
      <path d="m6 9 6 6 6-6"></path>
    </svg>
  </div>

  {
    error && (
      <p id={errorId} class="input-error" role="alert">
        {error}
      </p>
    )
  }
</div>

<style>
  .input-group {
    display: flex;
    flex-direction: column;
    gap: var(--space-2);
  }

  .input-label {
    font-family: var(--font-heading);
    font-size: var(--text-sm);
    font-weight: var(--font-medium);
    color: var(--color-charcoal);
  }

  .input-required {
    color: var(--color-error);
    margin-left: var(--space-1);
  }

  .input-hint {
    font-size: var(--text-sm);
    color: var(--color-gray-600);
    margin: 0;
  }

  .select-wrapper {
    position: relative;
    display: flex;
    align-items: center;
  }

  .select-field {
    width: 100%;
    padding: var(--space-3) var(--space-4);
    padding-right: var(--space-10);
    font-size: var(--text-base);
    line-height: var(--leading-normal);
    color: var(--color-charcoal);
    background-color: var(--color-white);
    border: 1px solid var(--color-gray-300);
    border-radius: var(--radius-sm);
    transition:
      border-color var(--transition-fast),
      box-shadow var(--transition-fast);
    appearance: none;
    cursor: pointer;
    /* Minimum touch target height */
    min-height: var(--touch-target-min);
  }

  .select-field:hover:not(:disabled) {
    border-color: var(--color-gray-400);
  }

  .select-field:focus {
    outline: none;
    border-color: var(--color-primary);
    box-shadow: 0 0 0 3px rgba(196, 30, 58, 0.1);
  }

  .select-field:disabled {
    background-color: var(--color-gray-100);
    cursor: not-allowed;
    opacity: 0.7;
  }

  .select-icon {
    position: absolute;
    right: var(--space-3);
    pointer-events: none;
    color: var(--color-gray-600);
  }

  /* Error state */
  .input-group--error .select-field {
    border-color: var(--color-error);
  }

  .input-group--error .select-field:focus {
    box-shadow: 0 0 0 3px rgba(198, 40, 40, 0.1);
  }

  .input-error {
    font-size: var(--text-sm);
    color: var(--color-error);
    margin: 0;
    display: flex;
    align-items: center;
    gap: var(--space-1);
  }

  .input-error::before {
    content: '!';
    display: inline-flex;
    align-items: center;
    justify-content: center;
    width: 16px;
    height: 16px;
    font-size: 12px;
    font-weight: var(--font-bold);
    background-color: var(--color-error);
    color: var(--color-white);
    border-radius: var(--radius-full);
  }
</style>
