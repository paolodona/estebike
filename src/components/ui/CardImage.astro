---
export interface Props {
  src?: string;
  alt: string;
  aspectRatio?: '16/9' | '4/3' | '1/1';
  overlay?: boolean;
  placeholder?: boolean;
}

const {
  src,
  alt,
  aspectRatio = '16/9',
  overlay = false,
  placeholder = false,
} = Astro.props;

const showPlaceholder = !src || placeholder;
---

<div class:list={['card-image', `card-image--${aspectRatio.replace('/', '-')}`, overlay && 'card-image--overlay', showPlaceholder && 'card-image--placeholder']}>
  {showPlaceholder ? (
    <div class="card-image__placeholder">
      <svg viewBox="0 0 120 40" width="120" height="40" fill="none" xmlns="http://www.w3.org/2000/svg">
        <text x="60" y="28" text-anchor="middle" font-family="Montserrat, sans-serif" font-weight="700" font-size="22" fill="rgba(255,255,255,0.7)">ESTEBIKE</text>
      </svg>
    </div>
  ) : (
    <img src={src} alt={alt} loading="lazy" />
  )}
</div>

<style>
  .card-image {
    position: relative;
    overflow: hidden;
  }

  .card-image img {
    width: 100%;
    height: 100%;
    object-fit: cover;
    transition: transform var(--transition-slow);
  }

  .card-image--overlay::after {
    content: '';
    position: absolute;
    inset: 0;
    background: linear-gradient(
      to bottom,
      transparent 0%,
      rgba(196, 30, 58, 0.1) 100%
    );
    opacity: 0;
    transition: opacity var(--transition-base);
  }

  :global(.card:hover) .card-image img {
    transform: scale(1.05);
  }

  :global(.card:hover) .card-image--overlay::after {
    opacity: 1;
  }

  /* Placeholder */
  .card-image--placeholder {
    background: linear-gradient(135deg, var(--color-primary) 0%, #8B1528 100%);
  }

  .card-image__placeholder {
    width: 100%;
    height: 100%;
    display: flex;
    align-items: center;
    justify-content: center;
  }

  /* Aspect ratios */
  .card-image--16-9 {
    aspect-ratio: 16 / 9;
  }

  .card-image--4-3 {
    aspect-ratio: 4 / 3;
  }

  .card-image--1-1 {
    aspect-ratio: 1 / 1;
  }
</style>
