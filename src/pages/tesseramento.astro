---
import BaseLayout from '../layouts/BaseLayout.astro';
import PageHeader from '../components/layout/PageHeader.astro';
import Button from '../components/ui/Button.astro';
import Icon from '../components/ui/Icon.astro';
import Badge from '../components/ui/Badge.astro';

const iban = 'IT54X0890462560036015009901';
const formUrl = 'https://docs.google.com/forms/d/e/1FAIpQLSfPwphvfoCXPuqr9wrAuA-pT9-frl3UsZjALaEfWy2BBc7rnA/viewform';

const benefits = [
  'Partecipazione alle uscite settimanali',
  'Copertura assicurativa R.C. verso terzi',
  'Sconti presso i nostri partner',
  'Accesso agli eventi riservati ai soci',
  'Supporto nella scelta dell\'attrezzatura',
];

const options = [
  {
    name: 'Socio Sostenitore',
    price: 30,
    description: 'Tessera amatoriale per partecipare a tutte le attività sociali del club.',
    badge: 'Amatoriale',
  },
  {
    name: 'Tesseramento Agonista FCI',
    price: 55,
    description: 'Tessera federale per partecipare a gare e competizioni ufficiali FCI.',
    badge: 'Agonista',
  },
];
---

<BaseLayout
  title="Tesseramento 2026"
  description="Tesseramento EsteBike 2026: socio sostenitore (€30) o agonista FCI (€55). Compila il form e effettua il bonifico. Iscrizioni aperte!"
>
  <PageHeader
    title="Tesseramento 2026"
    subtitle="Iscrizioni aperte!"
/>

  <!-- Options -->
  <section class="section">
    <div class="container">
      <div class="intro text-center">
        <Badge variant="accent">Anno 2026</Badge>
        <h2>Scegli la tua tessera</h2>
        <p>
          Due opzioni di tesseramento per entrare a far parte della famiglia EsteBike.
        </p>
      </div>

      <div class="options-grid">
        {options.map((opt) => (
          <div class="option-card">
            <Badge variant="primary" size="sm">{opt.badge}</Badge>
            <h3>{opt.name}</h3>
            <div class="option-price">
              <span class="option-price__amount">&euro;{opt.price}</span>
              <span class="option-price__label">quota annuale</span>
            </div>
            <p>{opt.description}</p>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- How to Register -->
  <section class="section section--light" id="come-tesserarsi">
    <div class="container">
      <div class="section-header text-center">
        <h2>Come tesserarsi</h2>
        <p>Due semplici passaggi</p>
      </div>

      <div class="steps-grid">
        <div class="step-card">
          <span class="step-number">1</span>
          <h3>Compila il form</h3>
          <p>
            Compila il modulo online con i tuoi dati anagrafici. Serve pochi minuti.
          </p>
          <Button href={formUrl} variant="primary" size="lg" fullWidth target="_blank" rel="noopener noreferrer">
            Compila il form
            <Icon name="arrow-right" size={18} />
          </Button>
        </div>

        <div class="step-card">
          <span class="step-number">2</span>
          <h3>Effettua il bonifico</h3>
          <p>
            Effettua un bonifico al conto EsteBike indicando come causale
            il tuo <strong>cognome/nome</strong> e il tipo di tessera scelta
            (socio sostenitore o tessera FCI).
          </p>
          <div class="iban-box">
            <span class="iban-label">IBAN (BCC Prealpi San Biagio)</span>
            <code class="iban-value" id="iban-value">{iban}</code>
            <button class="iban-copy" id="iban-copy" type="button" title="Copia IBAN">
              <Icon name="clipboard" size={18} />
            </button>
          </div>
          <div class="causale-example">
            <span class="causale-label">Esempio causale:</span>
            <code>Rossi Mario — Socio sostenitore</code>
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- FCI Notice -->
  <section class="section">
    <div class="container">
      <div class="fci-notice">
        <div class="fci-notice__icon">
          <Icon name="shield" size={28} />
        </div>
        <div class="fci-notice__content">
          <h3>Per i tesserati FCI (Agonisti)</h3>
          <p>
            Per il tesseramento agonista FCI occorre inviare a
            <a href="mailto:info@estebike.it">info@estebike.it</a>:
          </p>
          <ul>
            <li>Copia del certificato medico agonistico in corso di validità</li>
            <li>I propri dati anagrafici</li>
            <li>Una fototessera (se nuovo tesserato)</li>
          </ul>
          <p class="fci-warning">
            L'assenza del certificato medico nel sistema informatico FCI
            non permetterà l'iscrizione a gare e competizioni.
          </p>
        </div>
      </div>
    </div>
  </section>

  <!-- Benefits -->
  <section class="section section--light">
    <div class="container">
      <div class="benefits-section">
        <h2>Cosa include il tesseramento</h2>
        <ul class="benefits-list">
          {benefits.map((benefit) => (
            <li>
              <Icon name="chevron-right" size={18} />
              <span>{benefit}</span>
            </li>
          ))}
        </ul>

        <div class="insurance-warning">
          <Icon name="alert-triangle" size={20} />
          <p>
            In mancanza del tesseramento non è consentita la copertura
            dell'assicurazione R.C. verso terzi in caso di danni causati
            nell'esercizio dell'attività sociale.
          </p>
        </div>
      </div>
    </div>
  </section>

  <!-- FAQ Section -->
  <section class="section">
    <div class="container">
      <h2 class="text-center">Domande frequenti</h2>

      <div class="faq-grid">
        <div class="faq-item">
          <h3>Quando scade il tesseramento?</h3>
          <p>
            Il tesseramento ha validità annuale e segue l'anno solare
            (1 gennaio - 31 dicembre).
          </p>
        </div>

        <div class="faq-item">
          <h3>Posso partecipare al Magna & Pedala senza essere tesserato?</h3>
          <p>
            Sì, l'iscrizione al Magna & Pedala è aperta a tutti.
            Il tesseramento è richiesto solo per le attività regolari del club.
          </p>
        </div>

        <div class="faq-item">
          <h3>Come funziona la copertura assicurativa?</h3>
          <p>
            La tessera include una polizza assicurativa R.C. verso terzi che ti
            copre durante tutte le attività ufficiali del club.
          </p>
        </div>

        <div class="faq-item">
          <h3>Posso tesserarmi in qualsiasi momento dell'anno?</h3>
          <p>
            Sì, puoi tesserarti quando vuoi. La tessera sarà valida fino al
            31 dicembre dell'anno in corso.
          </p>
        </div>
      </div>
    </div>
  </section>
</BaseLayout>

<style>
  /* Intro */
  .intro {
    max-width: 600px;
    margin: 0 auto var(--space-10);
  }

  .intro h2 {
    margin: var(--space-4) 0;
  }

  .intro p {
    color: var(--color-gray-600);
    font-size: var(--text-lg);
  }

  /* Options Grid */
  .options-grid {
    display: grid;
    gap: var(--space-6);
  }

  @media (min-width: 768px) {
    .options-grid {
      grid-template-columns: repeat(2, 1fr);
    }
  }

  .option-card {
    background-color: var(--color-white);
    border: 2px solid var(--color-gray-200);
    border-radius: var(--radius-md);
    padding: var(--space-6);
    text-align: center;
  }

  .option-card h3 {
    font-size: var(--text-xl);
    margin: var(--space-3) 0 var(--space-2);
  }

  .option-price {
    display: flex;
    flex-direction: column;
    align-items: center;
    margin-bottom: var(--space-4);
    padding-bottom: var(--space-4);
    border-bottom: 1px solid var(--color-gray-200);
  }

  .option-price__amount {
    font-family: var(--font-heading);
    font-size: var(--text-4xl);
    font-weight: var(--font-bold);
    color: var(--color-primary);
    line-height: 1;
  }

  .option-price__label {
    font-size: var(--text-sm);
    color: var(--color-gray-600);
    margin-top: var(--space-1);
  }

  .option-card > p {
    font-size: var(--text-sm);
    color: var(--color-gray-600);
    line-height: var(--leading-relaxed);
    margin: 0;
  }

  /* Section Header */
  .section-header {
    margin-bottom: var(--space-8);
  }

  .section-header h2 {
    margin-bottom: var(--space-2);
  }

  .section-header p {
    color: var(--color-gray-600);
    margin: 0;
  }

  /* Steps Grid */
  .steps-grid {
    display: grid;
    gap: var(--space-6);
  }

  @media (min-width: 768px) {
    .steps-grid {
      grid-template-columns: repeat(2, 1fr);
    }
  }

  .step-card {
    background-color: var(--color-white);
    border-radius: var(--radius-md);
    padding: var(--space-6);
    box-shadow: var(--shadow-sm);
  }

  @media (min-width: 768px) {
    .step-card {
      padding: var(--space-8);
    }
  }

  .step-number {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    width: 36px;
    height: 36px;
    background-color: var(--color-primary);
    color: var(--color-white);
    border-radius: 50%;
    font-family: var(--font-heading);
    font-size: var(--text-lg);
    font-weight: var(--font-bold);
    margin-bottom: var(--space-4);
  }

  .step-card h3 {
    font-size: var(--text-xl);
    margin-bottom: var(--space-3);
  }

  .step-card > p {
    color: var(--color-gray-600);
    line-height: var(--leading-relaxed);
    margin-bottom: var(--space-6);
  }

  /* IBAN Box */
  .iban-box {
    display: flex;
    flex-direction: column;
    gap: var(--space-2);
    padding: var(--space-4);
    background-color: var(--color-off-white);
    border-radius: var(--radius-md);
    margin-bottom: var(--space-4);
    position: relative;
  }

  .iban-label {
    font-size: var(--text-xs);
    color: var(--color-gray-500);
    text-transform: uppercase;
    letter-spacing: 0.05em;
  }

  .iban-value {
    font-size: var(--text-sm);
    font-weight: var(--font-semibold);
    color: var(--color-charcoal);
    letter-spacing: 0.02em;
    word-break: break-all;
  }

  .iban-copy {
    position: absolute;
    top: var(--space-3);
    right: var(--space-3);
    background: none;
    border: none;
    color: var(--color-gray-500);
    cursor: pointer;
    padding: var(--space-1);
    border-radius: var(--radius-sm);
    transition: color var(--transition-fast);
  }

  .iban-copy:hover {
    color: var(--color-primary);
  }

  /* Causale example */
  .causale-example {
    display: flex;
    flex-direction: column;
    gap: var(--space-1);
  }

  .causale-label {
    font-size: var(--text-xs);
    color: var(--color-gray-500);
  }

  .causale-example code {
    font-size: var(--text-sm);
    color: var(--color-gray-700);
  }

  /* FCI Notice */
  .fci-notice {
    display: flex;
    gap: var(--space-6);
    padding: var(--space-6);
    background-color: var(--color-off-white);
    border-radius: var(--radius-md);
    border-left: 4px solid var(--color-primary);
    max-width: 800px;
    margin: 0 auto;
  }

  @media (max-width: 639px) {
    .fci-notice {
      flex-direction: column;
      gap: var(--space-3);
    }
  }

  .fci-notice__icon :global(.icon) {
    color: var(--color-primary);
    flex-shrink: 0;
  }

  .fci-notice__content h3 {
    font-size: var(--text-lg);
    margin-bottom: var(--space-3);
  }

  .fci-notice__content p {
    font-size: var(--text-sm);
    color: var(--color-gray-600);
    line-height: var(--leading-relaxed);
    margin-bottom: var(--space-3);
  }

  .fci-notice__content a {
    color: var(--color-primary);
    font-weight: var(--font-semibold);
  }

  .fci-notice__content ul {
    margin: 0 0 var(--space-3);
    padding-left: var(--space-5);
  }

  .fci-notice__content ul li {
    font-size: var(--text-sm);
    color: var(--color-gray-600);
    line-height: var(--leading-relaxed);
    margin-bottom: var(--space-1);
  }

  .fci-warning {
    font-weight: var(--font-semibold);
    color: var(--color-charcoal) !important;
  }

  /* Benefits */
  .benefits-section {
    max-width: 700px;
    margin: 0 auto;
  }

  .benefits-section h2 {
    margin-bottom: var(--space-6);
  }

  .benefits-list {
    list-style: none;
    padding: 0;
    margin: 0 0 var(--space-8);
  }

  .benefits-list li {
    display: flex;
    align-items: center;
    gap: var(--space-3);
    padding: var(--space-3) 0;
    border-bottom: 1px solid var(--color-gray-200);
  }

  .benefits-list :global(.icon) {
    color: var(--color-primary);
    flex-shrink: 0;
  }

  .insurance-warning {
    display: flex;
    align-items: flex-start;
    gap: var(--space-3);
    padding: var(--space-4);
    background-color: rgba(198, 40, 40, 0.08);
    border: 1px solid var(--color-error);
    border-radius: var(--radius-md);
  }

  .insurance-warning :global(.icon) {
    color: var(--color-error);
    flex-shrink: 0;
    margin-top: 2px;
  }

  .insurance-warning p {
    font-size: var(--text-sm);
    color: var(--color-charcoal);
    line-height: var(--leading-relaxed);
    margin: 0;
  }

  /* FAQ Grid */
  .faq-grid {
    display: grid;
    gap: var(--space-6);
    margin-top: var(--space-8);
  }

  @media (min-width: 768px) {
    .faq-grid {
      grid-template-columns: repeat(2, 1fr);
    }
  }

  .faq-item {
    padding: var(--space-6);
    background-color: var(--color-off-white);
    border-radius: var(--radius-md);
  }

  .faq-item h3 {
    font-size: var(--text-lg);
    margin-bottom: var(--space-3);
  }

  .faq-item p {
    font-size: var(--text-sm);
    color: var(--color-gray-600);
    line-height: var(--leading-relaxed);
    margin: 0;
  }
</style>

<script>
  const copyBtn = document.getElementById('iban-copy');
  const ibanVal = document.getElementById('iban-value');

  copyBtn?.addEventListener('click', async () => {
    if (ibanVal) {
      try {
        await navigator.clipboard.writeText(ibanVal.textContent?.trim() || '');
        copyBtn.title = 'Copiato!';
        setTimeout(() => { copyBtn.title = 'Copia IBAN'; }, 2000);
      } catch {
        // fallback: select text
        const range = document.createRange();
        range.selectNodeContents(ibanVal);
        const sel = window.getSelection();
        sel?.removeAllRanges();
        sel?.addRange(range);
      }
    }
  });
</script>
