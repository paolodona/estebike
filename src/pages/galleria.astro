---
import BaseLayout from '../layouts/BaseLayout.astro';
import PageHeader from '../components/layout/PageHeader.astro';
import Icon from '../components/ui/Icon.astro';

// Auto-generate gallery from filesystem: public/images/gallery/YYYY/MM/*.jpg
// This scans the directory structure so /wa-gallery-pull just needs to add files
const galleryDir = 'public/images/gallery';
const monthNames: Record<string, string> = {
  '01': 'Gennaio', '02': 'Febbraio', '03': 'Marzo', '04': 'Aprile',
  '05': 'Maggio', '06': 'Giugno', '07': 'Luglio', '08': 'Agosto',
  '09': 'Settembre', '10': 'Ottobre', '11': 'Novembre', '12': 'Dicembre',
};

// Load image descriptions from metadata file (generated by /wa-gallery-pull)
const fs = await import('node:fs');
const path = await import('node:path');

const descriptionsPath = path.resolve('scripts/whatsapp-gallery/descriptions.json');
const descriptions: Record<string, string> = fs.existsSync(descriptionsPath)
  ? JSON.parse(fs.readFileSync(descriptionsPath, 'utf-8'))
  : {};

function filenameToAlt(filename: string): string {
  // Check descriptions.json first
  if (descriptions[filename]) return descriptions[filename];

  // Fallback: generate Italian alt text from sender name in filename
  const match = filename.match(/estebike_\d+_(.+)\.jpg$/);
  if (!match) return 'Foto EsteBike';
  const sender = match[1].replace(/_/g, ' ').replace(/\d{2,}/g, '').trim();
  if (!sender || sender === 'unknown') return 'Foto dal gruppo EsteBike';
  if (sender.startsWith('You')) {
    const caption = sender.replace('You', '').trim();
    return caption.length > 2 ? caption : 'Foto dal gruppo EsteBike';
  }
  // Extract first name before camelCase or message text
  const name = sender.split(/(?=[A-Z])/)[0];
  return `${name} - uscita in bici`;
}
const whatsappGallery: { month: string; id: string; images: { src: string; alt: string }[] }[] = [];

const galleryPath = path.resolve(galleryDir);
if (fs.existsSync(galleryPath)) {
  const years = fs.readdirSync(galleryPath).filter((d: string) => /^\d{4}$/.test(d)).sort().reverse();
  for (const year of years) {
    const yearPath = path.join(galleryPath, year);
    const months = fs.readdirSync(yearPath).filter((d: string) => /^\d{2}$/.test(d)).sort().reverse();
    for (const month of months) {
      const monthPath = path.join(yearPath, month);
      const files = fs.readdirSync(monthPath).filter((f: string) => /\.(jpg|jpeg|webp|png)$/i.test(f)).sort();
      if (files.length === 0) continue;
      whatsappGallery.push({
        month: `${monthNames[month] || month} ${year}`,
        id: `${year}-${month}`,
        images: files.map((f: string) => ({
          src: `/images/gallery/${year}/${month}/${f}`,
          alt: filenameToAlt(f),
        })),
      });
    }
  }
}

// Legacy gallery from blog photos
const legacyGalleries = [
  {
    month: 'Magna & Pedala 2018',
    id: '2018',
    images: [
      { src: '/images/blog/2018/05/magnaepedala.jpg', alt: 'Magna e Pedala 2018' },
      { src: '/images/blog/2018/05/magnaepedala-b.jpg', alt: 'Volantino Magna e Pedala 2018' },
      { src: '/images/blog/2018/04/assemblea-soci_b.jpg', alt: 'Assemblea soci 2018' },
      { src: '/images/about-team.jpg', alt: 'Team EsteBike' },
      { src: '/images/about-preview.jpg', alt: 'Ciclisti in gruppo' },
      { src: '/images/pasta-party.jpg', alt: 'Pasta party finale' },
    ],
  },
  {
    month: 'Magna & Pedala 2017',
    id: '2017',
    images: [
      { src: '/images/blog/2017/05/magna-e-pedala-volantino.jpg', alt: 'Volantino Magna e Pedala 2017' },
      { src: '/images/blog/2017/04/7guadi-2.jpg', alt: 'Gara 7 Guadi 2017' },
      { src: '/images/blog/2017/02/team-agonisti-2017.jpg', alt: 'Team agonisti 2017' },
    ],
  },
  {
    month: 'Edizioni precedenti',
    id: 'legacy',
    images: [
      { src: '/images/blog/2016/05/magna-pedala-2016.jpg', alt: 'Magna e Pedala 2016' },
      { src: '/images/blog/2016/04/soci_oo.jpg', alt: 'Soci EsteBike 2016' },
      { src: '/images/blog/2015/05/magna-e-pedalata-2015.jpg', alt: 'Magna e Pedala 2015' },
      { src: '/images/blog/2015/05/MAGNAEPEDALA-BAONE.jpg', alt: 'Magna e Pedala a Baone' },
      { src: '/images/blog/2015/04/FOTO-ESTEBIKE-001b.jpg', alt: 'Gruppo EsteBike 2015' },
      { src: '/images/blog/2015/10/squadra_1.jpg', alt: 'Squadra EsteBike' },
    ],
  },
];

// Bundle small month sections (<=4 photos) with adjacent section in the same year
function bundleSmallSections(sections: typeof whatsappGallery) {
  const bundled: typeof whatsappGallery = [];
  for (const section of sections) {
    const prev = bundled[bundled.length - 1];
    const curYear = section.id.split('-')[0];
    const prevYear = prev?.id.split('-')[0];
    if (prev && prevYear === curYear && section.images.length <= 4) {
      // Merge into previous section within same year
      const prevMonth = prev.month.match(/^(\S+?)(?:-\S+)?\s+/)?.[1] || prev.month;
      const curMonth = section.month.match(/^(\S+)/)?.[1] || section.month;
      prev.month = `${prevMonth}-${curMonth} ${curYear}`;
      prev.images.push(...section.images);
    } else {
      bundled.push({ ...section });
    }
  }
  return bundled;
}

const allGalleries = [...bundleSmallSections(whatsappGallery), ...legacyGalleries];
const totalPhotos = allGalleries.reduce((sum, g) => sum + g.images.length, 0);
---

<BaseLayout
  title="Galleria"
  description="Foto e video delle nostre attività e degli eventi EsteBike. Rivivi i momenti più belli del Magna & Pedala e delle uscite in bici."
>
  <PageHeader
    title="Galleria"
    subtitle={`${totalPhotos} foto dalle nostre attività`}
    breadcrumbs={[{ label: 'Galleria' }]}
  />

  <section class="section gallery-page">
    <div class="container">
      {allGalleries.map((gallery) => (
        <div class="month-section" id={gallery.id}>
          <div class="month-header">
            <h2>{gallery.month}</h2>
            <span class="photo-count">{gallery.images.length} foto</span>
          </div>

          <div class="masonry-grid">
            {gallery.images.map((image, index) => (
              <button
                class="photo-item"
                data-lightbox
                data-src={image.src}
                data-alt={image.alt}
                data-gallery={gallery.id}
              >
                <img
                  src={image.src}
                  alt={image.alt}
                  loading="lazy"
                  decoding="async"
                />
              </button>
            ))}
          </div>
        </div>
      ))}
    </div>
  </section>

  <!-- Lightbox Modal -->
  <div class="lightbox" id="lightbox" hidden aria-modal="true" role="dialog" tabindex="-1">
    <div class="lightbox__backdrop" data-lightbox-close></div>
    <div class="lightbox__content">
      <div class="lightbox__topbar">
        <span class="lightbox__counter" id="lightbox-counter"></span>
        <button class="lightbox__close" data-lightbox-close aria-label="Chiudi">
          <Icon name="x" size={24} />
        </button>
      </div>
      <button class="lightbox__nav lightbox__nav--prev" data-lightbox-prev aria-label="Immagine precedente">
        <Icon name="chevron-left" size={32} />
      </button>
      <button class="lightbox__nav lightbox__nav--next" data-lightbox-next aria-label="Immagine successiva">
        <Icon name="chevron-right" size={32} />
      </button>
      <figure class="lightbox__figure">
        <img id="lightbox-image" src="" alt="" />
        <figcaption id="lightbox-caption"></figcaption>
      </figure>
    </div>
  </div>
</BaseLayout>

<style>
  /* Google Photos-style gallery */
  .gallery-page {
    padding-bottom: var(--space-16);
  }

  .month-section {
    margin-bottom: var(--space-10);
  }

  .month-section:last-child {
    margin-bottom: 0;
  }

  .month-header {
    display: flex;
    align-items: baseline;
    gap: var(--space-3);
    margin-bottom: var(--space-4);
    padding-bottom: var(--space-2);
    position: sticky;
    top: 0;
    z-index: 10;
    background: var(--color-white);
    padding-top: var(--space-3);
  }

  .month-header h2 {
    font-size: 1.1rem;
    font-weight: 600;
    margin: 0;
    letter-spacing: -0.01em;
  }

  .photo-count {
    font-size: var(--text-sm);
    color: var(--color-gray-400);
    font-weight: 400;
  }

  /* Masonry-like grid using CSS columns */
  .masonry-grid {
    column-count: 2;
    column-gap: 4px;
  }

  @media (min-width: 640px) {
    .masonry-grid {
      column-count: 3;
      column-gap: 4px;
    }
  }

  @media (min-width: 900px) {
    .masonry-grid {
      column-count: 4;
      column-gap: 4px;
    }
  }

  @media (min-width: 1200px) {
    .masonry-grid {
      column-count: 5;
      column-gap: 4px;
    }
  }

  .photo-item {
    display: block;
    width: 100%;
    margin-bottom: 4px;
    break-inside: avoid;
    overflow: hidden;
    border-radius: var(--radius-md);
    cursor: pointer;
    background: var(--color-gray-100);
    border: none;
    padding: 0;
    position: relative;
  }

  .photo-item img {
    display: block;
    width: 100%;
    height: auto;
    transition: transform 0.2s ease, filter 0.2s ease;
  }

  .photo-item:hover img {
    transform: scale(1.03);
    filter: brightness(0.9);
  }

  .photo-item:focus-visible {
    outline: 3px solid var(--color-primary);
    outline-offset: 2px;
    border-radius: var(--radius-sm);
  }

  /* Lightbox - fullscreen overlay */
  .lightbox {
    position: fixed;
    inset: 0;
    z-index: var(--z-modal);
    display: flex;
    align-items: center;
    justify-content: center;
  }

  .lightbox[hidden] {
    display: none;
  }

  .lightbox__backdrop {
    position: absolute;
    inset: 0;
    background-color: rgba(0, 0, 0, 0.95);
    cursor: pointer;
  }

  .lightbox__content {
    position: relative;
    width: 100%;
    height: 100%;
    display: flex;
    align-items: center;
    justify-content: center;
  }

  .lightbox__topbar {
    position: absolute;
    top: 0;
    left: 0;
    right: 0;
    display: flex;
    align-items: center;
    justify-content: space-between;
    padding: var(--space-3) var(--space-4);
    z-index: 2;
    background: linear-gradient(to bottom, rgba(0,0,0,0.5), transparent);
  }

  .lightbox__counter {
    color: rgba(255,255,255,0.8);
    font-size: var(--text-sm);
    font-weight: 500;
  }

  .lightbox__close {
    display: flex;
    align-items: center;
    justify-content: center;
    width: var(--touch-target-min);
    height: var(--touch-target-min);
    color: var(--color-white);
    background: none;
    border: none;
    cursor: pointer;
    border-radius: var(--radius-full);
    transition: background-color var(--transition-fast);
  }

  .lightbox__close:hover {
    background-color: rgba(255,255,255,0.1);
  }

  .lightbox__nav {
    position: absolute;
    top: 50%;
    transform: translateY(-50%);
    display: flex;
    align-items: center;
    justify-content: center;
    width: var(--touch-target-min);
    height: var(--touch-target-min);
    color: var(--color-white);
    background-color: rgba(0, 0, 0, 0.3);
    border: none;
    border-radius: var(--radius-full);
    cursor: pointer;
    z-index: 2;
    transition: background-color var(--transition-fast);
  }

  .lightbox__nav:hover {
    background-color: rgba(0, 0, 0, 0.6);
  }

  .lightbox__nav--prev {
    left: var(--space-3);
  }

  .lightbox__nav--next {
    right: var(--space-3);
  }

  .lightbox__figure {
    margin: 0;
    text-align: center;
    max-width: 95vw;
    max-height: 95vh;
    z-index: 1;
  }

  .lightbox__figure img {
    max-width: 95vw;
    max-height: 90vh;
    object-fit: contain;
    border-radius: 2px;
  }

  .lightbox__figure figcaption {
    position: absolute;
    bottom: var(--space-4);
    left: 50%;
    transform: translateX(-50%);
    color: rgba(255,255,255,0.8);
    font-size: var(--text-sm);
    background: rgba(0,0,0,0.5);
    padding: var(--space-1) var(--space-3);
    border-radius: var(--radius-md);
    white-space: nowrap;
    max-width: 80vw;
    overflow: hidden;
    text-overflow: ellipsis;
  }

  /* Scroll-driven fade-in for lazy loaded images */
  @keyframes fadeIn {
    from { opacity: 0; transform: scale(0.98); }
    to { opacity: 1; transform: scale(1); }
  }

  .photo-item img {
    animation: fadeIn 0.3s ease-out;
  }
</style>

<script>
  const lightbox = document.getElementById('lightbox');
  const lightboxImage = document.getElementById('lightbox-image') as HTMLImageElement;
  const lightboxCaption = document.getElementById('lightbox-caption');
  const lightboxCounter = document.getElementById('lightbox-counter');

  let currentGallery: string | null = null;
  let currentIndex = 0;
  let galleryImages: { src: string; alt: string }[] = [];

  function getGalleryImages(gallery: string) {
    const items = document.querySelectorAll(`[data-gallery="${gallery}"]`);
    return Array.from(items).map((item) => ({
      src: item.getAttribute('data-src') || '',
      alt: item.getAttribute('data-alt') || '',
    }));
  }

  function openLightbox(gallery: string, index: number) {
    currentGallery = gallery;
    currentIndex = index;
    galleryImages = getGalleryImages(gallery);
    updateLightboxImage();
    lightbox?.removeAttribute('hidden');
    document.body.style.overflow = 'hidden';
    lightbox?.focus();
  }

  function closeLightbox() {
    lightbox?.setAttribute('hidden', '');
    document.body.style.overflow = '';
  }

  function updateLightboxImage() {
    const image = galleryImages[currentIndex];
    if (lightboxImage && lightboxCaption && lightboxCounter) {
      lightboxImage.src = image.src;
      lightboxImage.alt = image.alt;
      lightboxCaption.textContent = image.alt;
      lightboxCounter.textContent = `${currentIndex + 1} / ${galleryImages.length}`;
    }
  }

  function navigateLightbox(direction: 'prev' | 'next') {
    if (direction === 'prev') {
      currentIndex = currentIndex > 0 ? currentIndex - 1 : galleryImages.length - 1;
    } else {
      currentIndex = currentIndex < galleryImages.length - 1 ? currentIndex + 1 : 0;
    }
    updateLightboxImage();
  }

  // Click handlers for gallery items
  document.querySelectorAll('[data-lightbox]').forEach((item) => {
    item.addEventListener('click', () => {
      const gallery = item.getAttribute('data-gallery') || '';
      const galleryItems = document.querySelectorAll(`[data-gallery="${gallery}"]`);
      const itemIndex = Array.from(galleryItems).indexOf(item);
      openLightbox(gallery, itemIndex);
    });
  });

  // Close
  document.querySelectorAll('[data-lightbox-close]').forEach((el) => {
    el.addEventListener('click', closeLightbox);
  });

  // Navigation buttons
  document.querySelector('[data-lightbox-prev]')?.addEventListener('click', () => navigateLightbox('prev'));
  document.querySelector('[data-lightbox-next]')?.addEventListener('click', () => navigateLightbox('next'));

  // Keyboard & touch
  document.addEventListener('keydown', (e) => {
    if (lightbox?.hasAttribute('hidden')) return;
    switch (e.key) {
      case 'Escape': closeLightbox(); break;
      case 'ArrowLeft': navigateLightbox('prev'); break;
      case 'ArrowRight': navigateLightbox('next'); break;
    }
  });

  // Swipe support for mobile
  let touchStartX = 0;
  lightbox?.addEventListener('touchstart', (e) => {
    touchStartX = (e as TouchEvent).changedTouches[0].screenX;
  }, { passive: true });

  lightbox?.addEventListener('touchend', (e) => {
    const touchEndX = (e as TouchEvent).changedTouches[0].screenX;
    const diff = touchStartX - touchEndX;
    if (Math.abs(diff) > 50) {
      navigateLightbox(diff > 0 ? 'next' : 'prev');
    }
  }, { passive: true });
</script>
