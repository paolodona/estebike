---
import BaseLayout from '../layouts/BaseLayout.astro';
import Hero from '../components/layout/Hero.astro';
import Button from '../components/ui/Button.astro';
import Badge from '../components/ui/Badge.astro';
import Icon from '../components/ui/Icon.astro';
import Card from '../components/ui/Card.astro';
import CardBody from '../components/ui/CardBody.astro';

const eventbriteUrl = 'https://estebikemangnaepedala2026.eventbrite.com/';

const eventDetails = {
  date: 'Domenica 10 Maggio 2026',
  dateShort: '10 Maggio 2026',
  location: 'Castello Carrarese, Este',
  startTime: '08:00 - 09:30',
  doorsOpen: '07:30',
};

const routes = [
  {
    name: 'Circuito Corto',
    distance: '10 km',
    elevation: '-',
    price: '€10',
    ristori: 2,
    difficulty: 'Facile',
    type: 'A piedi o in bici',
    description: 'Perfetto per famiglie e principianti. Gratuito per under 14.',
    color: 'success',
    barColor: '#2E7D32',
  },
  {
    name: 'Circuito Gravel',
    distance: '55 km',
    elevation: '~600 m D+',
    price: '€15',
    ristori: 3,
    difficulty: 'Medio',
    type: 'Gravel',
    description: 'Strade bianche e sentieri attraverso i Colli Euganei.',
    color: 'warning',
    barColor: '#E8A000',
  },
  {
    name: 'Circuito MTB',
    distance: '50 km',
    elevation: '~700 m D+',
    price: '€15',
    ristori: 3,
    difficulty: 'Impegnativo',
    type: 'Mountain Bike',
    description: 'I sentieri più belli dei Colli Euganei per ciclisti allenati.',
    color: 'error',
    barColor: '#C41E3A',
  },
];
---

<BaseLayout
  title="Magna & Pedala 2026 — 30° Anniversario EsteBike"
  description="Magna & Pedala 2026, 30° Anniversario EsteBike. Domenica 10 Maggio, Castello Carrarese, Este. 3 circuiti (Corto, Gravel, MTB), ristori e pasta party. Iscriviti su Eventbrite!"
>
  <Hero
    title="Magna & Pedala 2026"
    subtitle="30° Anniversario del Club — La tradizione continua"
    date={eventDetails.dateShort}
    location={eventDetails.location}
    image="/images/hero-event.jpg"
    ctaText="Iscriviti su Eventbrite"
    ctaHref={eventbriteUrl}
    size="large"
  />

  <!-- Event Info -->
  <section class="section" id="evento">
    <div class="container">
      <div class="event-intro text-center">
        <Badge variant="accent">30° Anniversario</Badge>
        <h2>Pedala, cammina, mangia, divertiti!</h2>
        <p>
          Manifestazione non competitiva per scoprire i Colli Euganei a piedi,
          in MTB o in Gravel, con ristori e prodotti locali lungo il percorso.
        </p>
      </div>

      <div class="info-cards">
        <div class="info-card">
          <Icon name="calendar" size={32} />
          <span class="info-card__label">Data</span>
          <span class="info-card__value">{eventDetails.dateShort}</span>
        </div>
        <div class="info-card">
          <Icon name="map-pin" size={32} />
          <span class="info-card__label">Partenza</span>
          <span class="info-card__value">{eventDetails.location}</span>
        </div>
        <div class="info-card">
          <Icon name="clock" size={32} />
          <span class="info-card__label">Partenza libera</span>
          <span class="info-card__value">{eventDetails.startTime}</span>
        </div>
        <div class="info-card">
          <Icon name="route" size={32} />
          <span class="info-card__label">Circuiti</span>
          <span class="info-card__value">3</span>
        </div>
      </div>
    </div>
  </section>

  <!-- Routes -->
  <section class="section section--bg-image" id="percorsi">
    <div class="container">
      <div class="section-header text-center">
        <h2>I percorsi</h2>
        <p>A piedi, in MTB o in Gravel — c'è un circuito per tutti</p>
      </div>

      <div class="routes-grid">
        {routes.map((route) => (
          <Card variant="event">
            <div class="route-color-bar" style={`background-color: ${route.barColor};`}></div>
            <CardBody>
              <div class="route-head">
                <Badge variant={route.color as 'error' | 'warning' | 'success'} size="sm">
                  {route.difficulty}
                </Badge>
                <span class="route-type">{route.type}</span>
              </div>
              <h3 class="route-title">{route.name}</h3>
              <div class="route-stats">
                <div class="route-stat">
                  <span class="route-stat__value">{route.distance}</span>
                  <span class="route-stat__label">Distanza</span>
                </div>
                <div class="route-stat">
                  <span class="route-stat__value">{route.elevation}</span>
                  <span class="route-stat__label">Dislivello</span>
                </div>
                <div class="route-stat">
                  <span class="route-stat__value">{route.price}</span>
                  <span class="route-stat__label">Iscrizione</span>
                </div>
              </div>
              <p class="route-description">{route.description}</p>
              <p class="route-ristori">
                <Icon name="mountain" size={14} />
                {route.ristori} ristori con prodotti locali
              </p>
            </CardBody>
          </Card>
        ))}
      </div>

      <p class="gps-note text-center">
        Le tracce GPS digitali saranno disponibili il giorno dell'evento tramite QR code.
      </p>
    </div>
  </section>

  <!-- What's Included + Photo -->
  <section class="section">
    <div class="container">
      <div class="included-grid">
        <div class="included-content">
          <h2>Cosa include</h2>
          <ul class="included-list">
            <li><Icon name="route" size={20} /> <span>Percorsi segnalati con tracce GPS</span></li>
            <li><Icon name="mountain" size={20} /> <span>Ristori con prodotti locali</span></li>
            <li><Icon name="calendar" size={20} /> <span>Pasta party finale</span></li>
            <li><Icon name="users" size={20} /> <span>Parcheggio gratuito</span></li>
          </ul>
        </div>
        <div class="included-image">
          <img
            src="/images/pasta-party.jpg"
            alt="Magna & Pedala — ristoro e pasta party"
            loading="lazy"
          />
        </div>
      </div>
    </div>
  </section>

  <!-- Practical Info -->
  <section class="section section--bg-image" id="info">
    <div class="container">
      <div class="section-header text-center">
        <h2>Informazioni pratiche</h2>
      </div>

      <div class="practical-grid">
        <div class="practical-item">
          <Icon name="clock" size={24} />
          <h3>Orari</h3>
          <p>Apertura: 07:30<br />Partenza libera: 08:00 — 09:30<br />Dall'Arena del Castello</p>
        </div>
        <div class="practical-item">
          <Icon name="shield" size={24} />
          <h3>Sicurezza</h3>
          <p>Casco obbligatorio per i ciclisti. Percorsi non sorvegliati: rispettare il codice della strada.</p>
        </div>
        <div class="practical-item">
          <Icon name="map-pin" size={24} />
          <h3>Come arrivare</h3>
          <p>Castello Carrarese, Via G. Negri, Este (PD). Parcheggio gratuito disponibile.</p>
        </div>
        <div class="practical-item">
          <Icon name="users" size={24} />
          <h3>Per tutti</h3>
          <p>Under 14 gratis sul circuito corto. Cani ammessi al guinzaglio.</p>
        </div>
      </div>
    </div>
  </section>

  <!-- Registration CTA -->
  <section class="section section--primary" id="iscrizioni">
    <div class="container">
      <div class="cta-content text-center">
        <h2>Iscriviti e festeggia con noi il 30° anniversario!</h2>
        <p>
          Le iscrizioni sono aperte su Eventbrite. Scegli il tuo circuito e
          assicurati il tuo posto alla partenza.
        </p>

        <div class="qr-section">
          <img
            src="/images/eventbrite-qr.svg"
            alt="QR code per la pagina Eventbrite del Magna & Pedala 2026"
            class="qr-code"
            width="160"
            height="160"
          />
          <p class="qr-hint">Inquadra con il telefono</p>
        </div>

        <div class="cta-actions">
          <Button href={eventbriteUrl} variant="accent" size="lg" target="_blank" rel="noopener noreferrer">
            Iscriviti su Eventbrite
          </Button>
          <Button href="/downloads/volantino-magna-pedala-2026.pdf" variant="ghost" size="lg" target="_blank">
            <Icon name="download" size={18} />
            Scarica il volantino
          </Button>
        </div>

        <p class="cta-email">
          Domande? Scrivi a <a href="mailto:eventi@estebike.it">eventi@estebike.it</a>
        </p>
      </div>
    </div>
  </section>
</BaseLayout>

<style>
  /* Background Image Sections */
  .section--bg-image {
    position: relative;
    background: url('/images/colli-euganei-bg.jpg') center/cover no-repeat fixed;
  }

  .section--bg-image::before {
    content: '';
    position: absolute;
    inset: 0;
    background: rgba(255, 255, 255, 0.88);
  }

  .section--bg-image > .container {
    position: relative;
    z-index: 1;
  }

  /* Event Intro */
  .event-intro {
    max-width: 700px;
    margin: 0 auto var(--space-10);
  }

  .event-intro h2 {
    margin: var(--space-4) 0;
  }

  .event-intro p {
    color: var(--color-gray-600);
    font-size: var(--text-lg);
    line-height: var(--leading-relaxed);
  }

  /* Info Cards */
  .info-cards {
    display: grid;
    gap: var(--space-4);
    grid-template-columns: repeat(2, 1fr);
  }

  @media (min-width: 768px) {
    .info-cards {
      grid-template-columns: repeat(4, 1fr);
    }
  }

  .info-card {
    display: flex;
    flex-direction: column;
    align-items: center;
    text-align: center;
    padding: var(--space-6);
    background-color: var(--color-off-white);
    border-radius: var(--radius-md);
    gap: var(--space-2);
  }

  .info-card :global(.icon) {
    color: var(--color-primary);
  }

  .info-card__label {
    font-size: var(--text-sm);
    color: var(--color-gray-600);
  }

  .info-card__value {
    font-family: var(--font-heading);
    font-size: var(--text-lg);
    font-weight: var(--font-bold);
    color: var(--color-charcoal);
  }

  /* Section Header */
  .section-header {
    margin-bottom: var(--space-8);
  }

  .section-header h2 {
    margin-bottom: var(--space-2);
  }

  .section-header p {
    color: var(--color-gray-600);
    margin: 0;
  }

  /* Routes Grid */
  .routes-grid {
    display: grid;
    gap: var(--space-6);
  }

  @media (min-width: 768px) {
    .routes-grid {
      grid-template-columns: repeat(3, 1fr);
    }
  }

  .route-color-bar {
    height: 4px;
    width: 100%;
  }

  .route-head {
    display: flex;
    align-items: center;
    justify-content: space-between;
  }

  .route-type {
    font-size: var(--text-xs);
    color: var(--color-gray-500);
    text-transform: uppercase;
    letter-spacing: 0.05em;
  }

  .route-title {
    font-size: var(--text-xl);
    margin: var(--space-3) 0 var(--space-4);
  }

  .route-stats {
    display: flex;
    gap: var(--space-4);
    margin-bottom: var(--space-4);
    padding-bottom: var(--space-4);
    border-bottom: 1px solid var(--color-gray-200);
  }

  .route-stat {
    display: flex;
    flex-direction: column;
  }

  .route-stat__value {
    font-family: var(--font-heading);
    font-size: var(--text-lg);
    font-weight: var(--font-bold);
    color: var(--color-primary);
  }

  .route-stat__label {
    font-size: var(--text-xs);
    color: var(--color-gray-600);
    text-transform: uppercase;
    letter-spacing: 0.05em;
  }

  .route-description {
    font-size: var(--text-sm);
    color: var(--color-gray-600);
    line-height: var(--leading-relaxed);
    margin: 0 0 var(--space-3);
  }

  .route-ristori {
    display: flex;
    align-items: center;
    gap: var(--space-2);
    font-size: var(--text-xs);
    color: var(--color-gray-500);
    margin: 0;
  }

  .route-ristori :global(.icon) {
    color: var(--color-primary);
  }

  .gps-note {
    margin-top: var(--space-6);
    font-size: var(--text-sm);
    color: var(--color-gray-500);
  }

  /* Included Section */
  .included-grid {
    display: grid;
    gap: var(--space-8);
    align-items: center;
  }

  @media (min-width: 1024px) {
    .included-grid {
      grid-template-columns: 1fr 1fr;
      gap: var(--space-12);
    }
  }

  .included-content h2 {
    margin-bottom: var(--space-6);
  }

  .included-list {
    list-style: none;
    padding: 0;
    margin: 0;
  }

  .included-list li {
    display: flex;
    align-items: center;
    gap: var(--space-3);
    padding: var(--space-3) 0;
    border-bottom: 1px solid var(--color-gray-200);
    font-size: var(--text-lg);
  }

  .included-list :global(.icon) {
    color: var(--color-primary);
  }

  .included-image {
    border-radius: var(--radius-lg);
    overflow: hidden;
  }

  .included-image img {
    width: 100%;
    height: auto;
    aspect-ratio: 4/3;
    object-fit: cover;
  }

  /* Practical Info */
  .practical-grid {
    display: grid;
    gap: var(--space-6);
    grid-template-columns: 1fr;
  }

  @media (min-width: 640px) {
    .practical-grid {
      grid-template-columns: repeat(2, 1fr);
    }
  }

  @media (min-width: 1024px) {
    .practical-grid {
      grid-template-columns: repeat(4, 1fr);
    }
  }

  .practical-item {
    padding: var(--space-6);
    background-color: var(--color-white);
    border-radius: var(--radius-md);
    box-shadow: var(--shadow-sm);
  }

  .practical-item :global(.icon) {
    color: var(--color-primary);
    margin-bottom: var(--space-3);
  }

  .practical-item h3 {
    font-size: var(--text-lg);
    margin-bottom: var(--space-2);
  }

  .practical-item p {
    font-size: var(--text-sm);
    color: var(--color-gray-600);
    line-height: var(--leading-relaxed);
    margin: 0;
  }

  /* CTA Section */
  .cta-content {
    max-width: 600px;
    margin: 0 auto;
  }

  .cta-content h2 {
    color: var(--color-white);
  }

  .cta-content > p {
    font-size: var(--text-lg);
    opacity: 0.9;
    margin-bottom: var(--space-6);
  }

  .qr-section {
    display: flex;
    flex-direction: column;
    align-items: center;
    margin-bottom: var(--space-6);
  }

  .qr-code {
    width: 160px;
    height: 160px;
    background: white;
    padding: var(--space-3);
    border-radius: var(--radius-md);
  }

  .qr-hint {
    margin-top: var(--space-2);
    font-size: var(--text-sm);
    opacity: 0.8;
  }

  .cta-actions {
    display: flex;
    flex-direction: column;
    gap: var(--space-4);
    justify-content: center;
  }

  @media (min-width: 640px) {
    .cta-actions {
      flex-direction: row;
    }
  }

  .cta-email {
    margin-top: var(--space-6);
    font-size: var(--text-sm);
    opacity: 0.8;
  }

  .cta-email a {
    color: var(--color-white);
    font-weight: var(--font-semibold);
  }
</style>
