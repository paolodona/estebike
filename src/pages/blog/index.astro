---
import { getCollection } from 'astro:content';
import BaseLayout from '../../layouts/BaseLayout.astro';
import PageHeader from '../../components/layout/PageHeader.astro';
import Card from '../../components/ui/Card.astro';
import CardImage from '../../components/ui/CardImage.astro';
import CardBody from '../../components/ui/CardBody.astro';
import Badge from '../../components/ui/Badge.astro';
import { url } from '../../utils/base';

const allPosts = await getCollection('blog', ({ data }) => !data.draft);
const sortedPosts = allPosts.sort(
  (a, b) => b.data.date.valueOf() - a.data.date.valueOf()
);

const BATCH_SIZE = 10;

const formatDate = (date: Date) => {
  return new Intl.DateTimeFormat('it-IT', {
    day: 'numeric',
    month: 'long',
    year: 'numeric',
  }).format(date);
};
---

<BaseLayout
  title="Blog"
  description="News, comunicati e aggiornamenti dal mondo EsteBike. Resta informato sulle nostre attività e eventi."
>
  <PageHeader title="Blog" subtitle="News e aggiornamenti dal mondo EsteBike" />

  <section class="section">
    <div class="container">
      {
        sortedPosts.length > 0 ? (
          <div class="blog-grid" id="blog-grid" data-batch={BATCH_SIZE}>
            {sortedPosts.map((post, i) => (
              <Card
                variant="blog"
                href={`/blog/${post.slug}`}
                class:list={[{ 'blog-hidden': i >= BATCH_SIZE }]}
              >
                <CardImage src={post.data.image} alt={post.data.title} />
                <CardBody>
                  <Badge variant="primary" size="sm">
                    {post.data.category}
                  </Badge>
                  <h2 class="post-title">{post.data.title}</h2>
                  <time
                    class="post-date"
                    datetime={post.data.date.toISOString()}
                  >
                    {formatDate(post.data.date)}
                  </time>
                  {post.data.excerpt && (
                    <p class="post-excerpt">{post.data.excerpt}</p>
                  )}
                  <span class="post-link">Leggi tutto &rarr;</span>
                </CardBody>
              </Card>
            ))}
          </div>
        ) : (
          <p class="no-posts">Nessun articolo pubblicato.</p>
        )
      }

      <div id="blog-sentinel" class="blog-sentinel" aria-hidden="true"></div>

      {
        sortedPosts.length > BATCH_SIZE && (
          <p class="blog-loading" id="blog-loading">
            Caricamento...
          </p>
        )
      }
    </div>
  </section>
</BaseLayout>

<script>
  const grid = document.getElementById('blog-grid');
  const sentinel = document.getElementById('blog-sentinel');
  const loading = document.getElementById('blog-loading');

  if (grid && sentinel) {
    const batch = parseInt(grid.dataset.batch || '10', 10);
    const hidden = grid.querySelectorAll('.blog-hidden');
    let revealed = 0;

    if (hidden.length === 0 && loading) {
      loading.remove();
    }

    const observer = new IntersectionObserver(
      (entries) => {
        if (!entries[0].isIntersecting) return;

        const end = Math.min(revealed + batch, hidden.length);
        for (let i = revealed; i < end; i++) {
          hidden[i].classList.remove('blog-hidden');
        }
        revealed = end;

        if (revealed >= hidden.length) {
          observer.disconnect();
          if (loading) loading.remove();
        }
      },
      { rootMargin: '400px 0px' }
    );

    observer.observe(sentinel);
  }
</script>

<style>
  .blog-grid {
    display: grid;
    gap: var(--space-6);
    grid-template-columns: 1fr;
  }

  @media (min-width: 768px) {
    .blog-grid {
      grid-template-columns: repeat(2, 1fr);
    }
  }

  @media (min-width: 1024px) {
    .blog-grid {
      grid-template-columns: repeat(3, 1fr);
    }
  }

  .blog-hidden {
    display: none;
  }

  .post-title {
    font-size: var(--text-xl);
    font-weight: var(--font-semibold);
    margin: var(--space-3) 0 var(--space-2);
    line-height: var(--leading-snug);
  }

  .post-date {
    font-size: var(--text-sm);
    color: var(--color-gray-600);
    display: block;
    margin-bottom: var(--space-3);
  }

  .post-excerpt {
    font-size: var(--text-sm);
    color: var(--color-gray-800);
    line-height: var(--leading-relaxed);
    margin-bottom: var(--space-4);
    flex: 1;
  }

  .post-link {
    font-size: var(--text-sm);
    font-weight: var(--font-semibold);
    color: var(--color-primary);
    margin-top: auto;
  }

  .no-posts {
    text-align: center;
    color: var(--color-gray-600);
    padding: var(--space-12) 0;
  }

  .blog-sentinel {
    height: 1px;
  }

  .blog-loading {
    text-align: center;
    color: var(--color-gray-600);
    padding: var(--space-6) 0;
    font-size: var(--text-sm);
  }
</style>
