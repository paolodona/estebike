---
import { getCollection } from 'astro:content';
import BaseLayout from '../layouts/BaseLayout.astro';
import Hero from '../components/layout/Hero.astro';
import Card from '../components/ui/Card.astro';
import CardImage from '../components/ui/CardImage.astro';
import CardBody from '../components/ui/CardBody.astro';
import Badge from '../components/ui/Badge.astro';
import Button from '../components/ui/Button.astro';
import Icon from '../components/ui/Icon.astro';
import { url } from '../utils/base';

// Get latest blog posts
const allPosts = await getCollection('blog', ({ data }) => !data.draft);
const latestPosts = allPosts
  .sort((a, b) => b.data.date.valueOf() - a.data.date.valueOf())
  .slice(0, 3);

const formatDate = (date: Date) => {
  return new Intl.DateTimeFormat('it-IT', {
    day: 'numeric',
    month: 'short',
    year: 'numeric',
  }).format(date);
};


---

<BaseLayout
  title="EsteBike"
  description="EsteBike - Associazione ciclistica dal 1996. Scopri il Magna & Pedala, i nostri percorsi nei Colli Euganei e unisciti alla nostra community di ciclisti."
>
  <Hero
    title="Magna & Pedala 2026"
    subtitle="EsteBike presenta"
    date="10 Maggio 2026"
    location="Castello Carrarese, Este"
    image="/images/hero-default.jpg"
    ctaText="Iscriviti Ora"
    ctaHref="/magna-e-pedala#iscrizioni"
    secondaryCtaText="Scopri i Percorsi"
    secondaryCtaHref="/magna-e-pedala#percorsi"
  >
    <div class="countdown" id="countdown" aria-label="Conto alla rovescia per l'evento">
      <div class="countdown__item">
        <span class="countdown__value" id="cd-days">--</span>
        <span class="countdown__label">Giorni</span>
      </div>
      <div class="countdown__item">
        <span class="countdown__value" id="cd-hours">--</span>
        <span class="countdown__label">Ore</span>
      </div>
      <div class="countdown__item">
        <span class="countdown__value" id="cd-mins">--</span>
        <span class="countdown__label">Minuti</span>
      </div>
      <div class="countdown__item">
        <span class="countdown__value" id="cd-secs">--</span>
        <span class="countdown__label">Secondi</span>
      </div>
    </div>
  </Hero>

  <!-- About Section -->
  <section class="section">
    <div class="container">
      <div class="about-grid animate-on-scroll">
        <div class="about-content">
          <Badge variant="accent">Dal 1996</Badge>
          <h2>Passione per il ciclismo nel cuore dei Colli Euganei</h2>
          <p>
            EsteBike nasce dalla passione condivisa per le due ruote. Da quasi 30 anni
            organizziamo eventi ciclistici, uscite in gruppo e promuoviamo la cultura
            del ciclismo nel nostro territorio.
          </p>
          <p>
            Il nostro evento principale, il <strong>Magna & Pedala</strong>, celebra
            la tradizione ciclistica locale con percorsi adatti a tutti i livelli,
            immersi nel paesaggio unico dei Colli Euganei.
          </p>
          <Button href="/chi-siamo" variant="secondary">
            Scopri chi siamo
            <Icon name="arrow-right" size={18} />
          </Button>
        </div>
        <div class="about-image">
          <img
            src={url('/images/about-preview.jpg')}
            alt="Ciclisti EsteBike in gruppo sui Colli Euganei"
            loading="lazy"
          />
        </div>
      </div>
    </div>
  </section>

  <!-- Event CTA -->
  <section class="section event-cta-section">
    <div class="container">
      <div class="event-cta text-center animate-on-scroll">
        <h2>Partecipa al Magna & Pedala 2026</h2>
        <p>
          Unisciti a centinaia di ciclisti per una giornata di sport, natura e buon cibo.
          Ristori lungo il percorso, pasta party finale e tanto divertimento!
        </p>
        <div class="event-cta__actions">
          <Button href="/magna-e-pedala#iscrizioni" variant="accent" size="lg">
            Iscriviti Ora
          </Button>
          <Button href="/magna-e-pedala" variant="ghost" size="lg">
            Scopri l'evento
          </Button>
        </div>
      </div>
    </div>
  </section>

  <!-- Gallery Preview -->
  <section class="section section--light">
    <div class="container">
      <div class="section-header animate-on-scroll">
        <h2>Galleria</h2>
        <Button href="/galleria" variant="secondary" size="sm">
          Vedi tutte
          <Icon name="arrow-right" size={16} />
        </Button>
      </div>

      <div class="gallery-mosaic animate-on-scroll">
        <a href={url('/galleria')} class="gallery-mosaic__item gallery-mosaic__item--tall">
          <img src={url('/images/about-preview.jpg')} alt="Ciclisti in gruppo" loading="lazy" />
        </a>
        <a href={url('/galleria')} class="gallery-mosaic__item">
          <img src={url('/images/blog/2018/05/magnaepedala.jpg')} alt="Magna e Pedala 2018" loading="lazy" />
        </a>
        <a href={url('/galleria')} class="gallery-mosaic__item">
          <img src={url('/images/about-team.jpg')} alt="Team EsteBike" loading="lazy" />
        </a>
        <a href={url('/galleria')} class="gallery-mosaic__item">
          <img src={url('/images/blog/2017/02/team-agonisti-2017.jpg')} alt="Team agonisti 2017" loading="lazy" />
        </a>
        <a href={url('/galleria')} class="gallery-mosaic__item gallery-mosaic__item--tall">
          <img src={url('/images/pasta-party.jpg')} alt="Pasta party finale" loading="lazy" />
        </a>
        <a href={url('/galleria')} class="gallery-mosaic__item">
          <img src={url('/images/blog/2015/04/FOTO-ESTEBIKE-001b.jpg')} alt="Gruppo EsteBike" loading="lazy" />
        </a>
      </div>
    </div>
  </section>

  <!-- Latest News -->
  <section class="section">
    <div class="container">
      <div class="section-header">
        <h2>Ultime News</h2>
        <Button href="/blog" variant="secondary" size="sm">
          Vedi tutte
          <Icon name="arrow-right" size={16} />
        </Button>
      </div>

      {latestPosts.length > 0 ? (
        <div class="news-grid">
          {latestPosts.map((post) => (
            <Card variant="blog" href={`/blog/${post.slug}`}>
              <CardImage src={post.data.image} alt={post.data.title} />
              <CardBody>
                <Badge variant="primary" size="sm">{post.data.category}</Badge>
                <h3 class="post-title">{post.data.title}</h3>
                <time class="post-date" datetime={post.data.date.toISOString()}>
                  {formatDate(post.data.date)}
                </time>
                {post.data.excerpt && (
                  <p class="post-excerpt">{post.data.excerpt}</p>
                )}
              </CardBody>
            </Card>
          ))}
        </div>
      ) : (
        <p class="text-center text-muted">Nessun articolo pubblicato.</p>
      )}
    </div>
  </section>

  <!-- Contact CTA -->
  <section class="section section--light">
    <div class="container">
      <div class="contact-cta text-center animate-on-scroll">
        <h2>Resta in contatto</h2>
        <p>
          Organizziamo uscite settimanali in bicicletta:
        </p>
        <div class="rides-info">
          <div class="ride-detail">
            <Icon name="calendar" size={20} />
            <div>
              <strong>Sabato ore 9:00</strong>
              <span>Piazzale delle Piscine, Este</span>
            </div>
          </div>
          <div class="ride-detail">
            <Icon name="calendar" size={20} />
            <div>
              <strong>Domenica</strong>
              <span>Piazza "ai Leoni", Este</span>
            </div>
          </div>
          <div class="ride-detail">
            <Icon name="bike" size={20} />
            <div>
              <span>Mountain bike in inverno, bici da corsa in estate</span>
            </div>
          </div>
        </div>
        <p class="rides-note">
          Le uscite vengono organizzate tramite il gruppo WhatsApp,
          accessibile previo <a href={url('/tesseramento')}>tesseramento</a>.
        </p>
        <div class="contact-actions">
          <Button href="/contatti" variant="primary">
            Contattaci
          </Button>
          <Button href="https://www.instagram.com/team_estebike/" variant="secondary">
            <Icon name="instagram" size={18} />
            Seguici
          </Button>
        </div>
      </div>
    </div>
  </section>
</BaseLayout>

<style>
  /* Countdown */
  .countdown {
    display: flex;
    justify-content: center;
    gap: var(--space-4);
    margin-top: var(--space-6);
    position: relative;
    z-index: 2;
  }

  @media (min-width: 640px) {
    .countdown {
      gap: var(--space-6);
    }
  }

  .countdown__item {
    display: flex;
    flex-direction: column;
    align-items: center;
    min-width: 60px;
  }

  @media (min-width: 640px) {
    .countdown__item {
      min-width: 80px;
    }
  }

  .countdown__value {
    font-family: var(--font-heading);
    font-size: var(--text-3xl);
    font-weight: var(--font-bold);
    color: var(--color-accent);
    line-height: 1;
    text-shadow: 0 2px 4px rgba(0, 0, 0, 0.3);
  }

  @media (min-width: 640px) {
    .countdown__value {
      font-size: var(--text-5xl);
    }
  }

  .countdown__label {
    font-size: var(--text-xs);
    text-transform: uppercase;
    letter-spacing: 0.1em;
    color: rgba(255, 255, 255, 0.8);
    margin-top: var(--space-1);
  }

  /* Gallery Mosaic */
  .gallery-mosaic {
    display: grid;
    grid-template-columns: repeat(2, 1fr);
    grid-auto-rows: 180px;
    gap: var(--space-3);
  }

  @media (min-width: 768px) {
    .gallery-mosaic {
      grid-template-columns: repeat(3, 1fr);
      grid-auto-rows: 200px;
      gap: var(--space-4);
    }
  }

  .gallery-mosaic__item {
    display: block;
    border-radius: var(--radius-lg);
    overflow: hidden;
    position: relative;
  }

  .gallery-mosaic__item img {
    width: 100%;
    height: 100%;
    object-fit: cover;
    transition: transform var(--transition-slow);
  }

  .gallery-mosaic__item:hover img {
    transform: scale(1.05);
  }

  .gallery-mosaic__item--tall {
    grid-row: span 2;
  }

  /* Section Header */
  .section-header {
    display: flex;
    flex-direction: column;
    gap: var(--space-2);
    margin-bottom: var(--space-8);
  }

  @media (min-width: 768px) {
    .section-header {
      flex-direction: row;
      justify-content: space-between;
      align-items: center;
    }
  }

  .section-header.text-center {
    text-align: center;
    align-items: center;
    justify-content: center;
  }

  .section-header h2 {
    margin: 0;
  }

  .section-header p {
    color: var(--color-gray-600);
    margin: 0;
    max-width: 600px;
  }

  /* About Section */
  .about-grid {
    display: grid;
    gap: var(--space-8);
    align-items: center;
  }

  @media (min-width: 1024px) {
    .about-grid {
      grid-template-columns: 1fr 1fr;
      gap: var(--space-12);
    }
  }

  .about-content {
    display: flex;
    flex-direction: column;
    gap: var(--space-4);
  }

  .about-content h2 {
    font-size: var(--text-3xl);
    line-height: var(--leading-tight);
  }

  @media (min-width: 768px) {
    .about-content h2 {
      font-size: var(--text-4xl);
    }
  }

  .about-content p {
    color: var(--color-gray-800);
    line-height: var(--leading-relaxed);
  }

  .about-image {
    border-radius: var(--radius-lg);
    overflow: hidden;
  }

  .about-image img {
    width: 100%;
    height: auto;
    aspect-ratio: 4/3;
    object-fit: cover;
  }

  /* Routes Grid */
  .routes-grid {
    display: grid;
    gap: var(--space-6);
    grid-template-columns: 1fr;
  }

  @media (min-width: 768px) {
    .routes-grid {
      grid-template-columns: repeat(3, 1fr);
    }
  }

  .route-color-bar {
    height: 4px;
    width: 100%;
  }

  .route-name {
    font-size: var(--text-xl);
    margin: var(--space-3) 0 var(--space-2);
  }

  .route-stats {
    display: flex;
    gap: var(--space-4);
    font-size: var(--text-sm);
    color: var(--color-gray-600);
  }

  .route-stats span {
    display: flex;
    align-items: center;
    gap: var(--space-1);
  }

  /* Event CTA */
  .event-cta-section {
    position: relative;
    background: url('/images/colli-euganei-bg.jpg') center/cover no-repeat;
    color: var(--color-white);
  }

  .event-cta-section::before {
    content: '';
    position: absolute;
    inset: 0;
    background: linear-gradient(to bottom, rgba(196, 30, 58, 0.85), rgba(139, 21, 40, 0.92));
  }

  .event-cta-section > .container {
    position: relative;
    z-index: 1;
  }

  .event-cta {
    max-width: 700px;
    margin: 0 auto;
  }

  .event-cta h2 {
    color: var(--color-white);
    font-size: var(--text-3xl);
  }

  @media (min-width: 768px) {
    .event-cta h2 {
      font-size: var(--text-4xl);
    }
  }

  .event-cta p {
    font-size: var(--text-lg);
    opacity: 0.9;
    margin-bottom: var(--space-6);
  }

  .event-cta__actions {
    display: flex;
    flex-direction: column;
    gap: var(--space-4);
    justify-content: center;
  }

  @media (min-width: 640px) {
    .event-cta__actions {
      flex-direction: row;
    }
  }

  /* News Grid */
  .news-grid {
    display: grid;
    gap: var(--space-6);
    grid-template-columns: 1fr;
  }

  @media (min-width: 768px) {
    .news-grid {
      grid-template-columns: repeat(2, 1fr);
    }
  }

  @media (min-width: 1024px) {
    .news-grid {
      grid-template-columns: repeat(3, 1fr);
    }
  }

  .post-title {
    font-size: var(--text-lg);
    margin: var(--space-3) 0 var(--space-2);
    line-height: var(--leading-snug);
  }

  .post-date {
    font-size: var(--text-sm);
    color: var(--color-gray-600);
    display: block;
    margin-bottom: var(--space-3);
  }

  .post-excerpt {
    font-size: var(--text-sm);
    color: var(--color-gray-800);
    line-height: var(--leading-relaxed);
    margin: 0;
  }

  /* Contact CTA */
  .contact-cta {
    max-width: 600px;
    margin: 0 auto;
  }

  .contact-cta p {
    color: var(--color-gray-600);
    margin-bottom: var(--space-6);
  }

  .rides-info {
    display: flex;
    flex-direction: column;
    gap: var(--space-3);
    margin-bottom: var(--space-6);
    text-align: left;
    max-width: 400px;
    margin-left: auto;
    margin-right: auto;
  }

  .ride-detail {
    display: flex;
    align-items: center;
    gap: var(--space-3);
    color: var(--color-gray-800);
  }

  .ride-detail div {
    display: flex;
    flex-direction: column;
  }

  .ride-detail span {
    font-size: var(--text-sm);
    color: var(--color-gray-600);
  }

  .rides-note {
    font-size: var(--text-sm);
    color: var(--color-gray-600);
    margin-bottom: var(--space-6);
  }

  .rides-note a {
    color: var(--color-primary);
    font-weight: var(--font-semibold);
    text-decoration: underline;
  }

  .contact-actions {
    display: flex;
    flex-direction: column;
    gap: var(--space-4);
    justify-content: center;
  }

  @media (min-width: 640px) {
    .contact-actions {
      flex-direction: row;
    }
  }
</style>

<script>
  const EVENT_DATE = new Date('2026-05-10T07:30:00+02:00');

  function updateCountdown() {
    const now = new Date();
    const diff = EVENT_DATE.getTime() - now.getTime();

    if (diff <= 0) {
      const el = document.getElementById('countdown');
      if (el) el.innerHTML = '<p style="color: var(--color-accent); font-size: var(--text-xl); font-weight: bold;">L\'evento è oggi!</p>';
      return;
    }

    const days = Math.floor(diff / (1000 * 60 * 60 * 24));
    const hours = Math.floor((diff % (1000 * 60 * 60 * 24)) / (1000 * 60 * 60));
    const mins = Math.floor((diff % (1000 * 60 * 60)) / (1000 * 60));
    const secs = Math.floor((diff % (1000 * 60)) / 1000);

    const daysEl = document.getElementById('cd-days');
    const hoursEl = document.getElementById('cd-hours');
    const minsEl = document.getElementById('cd-mins');
    const secsEl = document.getElementById('cd-secs');

    if (daysEl) daysEl.textContent = String(days);
    if (hoursEl) hoursEl.textContent = String(hours).padStart(2, '0');
    if (minsEl) minsEl.textContent = String(mins).padStart(2, '0');
    if (secsEl) secsEl.textContent = String(secs).padStart(2, '0');
  }

  updateCountdown();
  setInterval(updateCountdown, 1000);
</script>
