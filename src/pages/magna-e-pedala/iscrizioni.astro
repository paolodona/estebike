---
import BaseLayout from '../../layouts/BaseLayout.astro';
import PageHeader from '../../components/layout/PageHeader.astro';
import Input from '../../components/ui/Input.astro';
import Radio from '../../components/ui/Radio.astro';
import Checkbox from '../../components/ui/Checkbox.astro';
import Button from '../../components/ui/Button.astro';
import Icon from '../../components/ui/Icon.astro';
import Badge from '../../components/ui/Badge.astro';

const routeOptions = [
  { value: 'lungo', label: 'Percorso Lungo (85 km - 1200 m D+)' },
  { value: 'medio', label: 'Percorso Medio (55 km - 700 m D+)' },
  { value: 'corto', label: 'Percorso Corto (35 km - 350 m D+)' },
];

const price = 25; // EUR
const apiUrl = import.meta.env.PUBLIC_API_URL || 'https://api.estebike.it';
---

<BaseLayout
  title="Iscrizioni"
  description="Iscriviti al Magna & Pedala 2026. Compila il modulo, scegli il tuo percorso e completa il pagamento online."
>
  <PageHeader
    title="Iscrizioni"
    subtitle="Magna & Pedala 2026"
    breadcrumbs={[
      { label: 'Magna & Pedala', href: '/magna-e-pedala' },
      { label: 'Iscrizioni' },
    ]}
  />

  <section class="section">
    <div class="container">
      <div class="registration-grid">
        <!-- Form -->
        <div class="form-container">
          <form id="registration-form" novalidate>
            <div class="form-section">
              <h2>Dati personali</h2>
              <div class="form-row">
                <Input
                  name="nome"
                  label="Nome"
                  required
                  autocomplete="given-name"
                />
                <Input
                  name="cognome"
                  label="Cognome"
                  required
                  autocomplete="family-name"
                />
              </div>
              <Input
                type="email"
                name="email"
                label="Email"
                required
                autocomplete="email"
              />
              <Input
                type="tel"
                name="telefono"
                label="Telefono"
                required
                autocomplete="tel"
                placeholder="Es. 333 1234567"
              />
            </div>

            <div class="form-section">
              <h2>Contatto di emergenza</h2>
              <p class="form-section__hint">
                In caso di necessità durante l'evento, chi possiamo contattare?
              </p>
              <Input
                name="contattoEmergenza"
                label="Nome e cognome"
                required
              />
              <Input
                type="tel"
                name="telefonoEmergenza"
                label="Telefono"
                required
                placeholder="Es. 333 1234567"
              />
            </div>

            <div class="form-section">
              <h2>Percorso</h2>
              <Radio
                name="percorso"
                legend="Scegli il percorso"
                options={routeOptions}
                required
              />
              <p class="form-section__hint">
                <a href="/magna-e-pedala/percorsi">Vedi i dettagli dei percorsi</a>
              </p>
            </div>

            <div class="form-section">
              <h2>Privacy e consensi</h2>
              <Checkbox
                name="consensoLista"
                label="Acconsento alla pubblicazione del mio nome e percorso scelto nella lista pubblica dei partecipanti"
              />
              <Checkbox
                name="consensoPrivacy"
                label="Ho letto e accetto l'informativa sulla privacy"
                required
              />
              <p class="form-section__hint">
                <a href="/privacy">Leggi l'informativa completa</a>
              </p>
            </div>

            <div class="form-error" id="form-error" hidden>
              <Icon name="x" size={20} />
              <span></span>
            </div>

            <Button type="submit" variant="primary" size="lg" fullWidth>
              Procedi al pagamento
            </Button>
          </form>
        </div>

        <!-- Sidebar -->
        <aside class="sidebar">
          <div class="price-card">
            <h3>Riepilogo</h3>
            <div class="price-card__event">
              <Badge variant="accent">2026</Badge>
              <span>Magna & Pedala</span>
            </div>
            <div class="price-card__price">
              <span class="price-card__amount">&euro;{price}</span>
              <span class="price-card__label">quota di iscrizione</span>
            </div>
            <ul class="price-card__includes">
              <li>
                <Icon name="route" size={18} />
                Percorso segnalato
              </li>
              <li>
                <Icon name="users" size={18} />
                Assistenza tecnica
              </li>
              <li>
                <Icon name="mountain" size={18} />
                Ristori lungo il percorso
              </li>
              <li>
                <Icon name="calendar" size={18} />
                Pasta party finale
              </li>
            </ul>
          </div>

          <div class="info-card">
            <h4>Hai bisogno di aiuto?</h4>
            <p>
              Per qualsiasi domanda sull'iscrizione, contattaci via email o WhatsApp.
            </p>
            <a href="/contatti" class="info-card__link">
              <Icon name="mail" size={18} />
              Contattaci
            </a>
          </div>
        </aside>
      </div>
    </div>
  </section>
</BaseLayout>

<style>
  .registration-grid {
    display: grid;
    gap: var(--space-10);
  }

  @media (min-width: 1024px) {
    .registration-grid {
      grid-template-columns: 1fr 380px;
      gap: var(--space-12);
    }
  }

  /* Form Container */
  .form-container {
    background-color: var(--color-white);
    border-radius: var(--radius-md);
    padding: var(--space-6);
    border: 1px solid var(--color-gray-200);
  }

  @media (min-width: 768px) {
    .form-container {
      padding: var(--space-8);
    }
  }

  .form-section {
    margin-bottom: var(--space-8);
    padding-bottom: var(--space-6);
    border-bottom: 1px solid var(--color-gray-200);
  }

  .form-section:last-of-type {
    border-bottom: none;
    margin-bottom: var(--space-6);
  }

  .form-section h2 {
    font-size: var(--text-xl);
    margin-bottom: var(--space-4);
  }

  .form-section__hint {
    font-size: var(--text-sm);
    color: var(--color-gray-600);
    margin-top: var(--space-2);
    margin-bottom: var(--space-4);
  }

  .form-section__hint a {
    color: var(--color-primary);
  }

  .form-row {
    display: grid;
    gap: var(--space-4);
  }

  @media (min-width: 640px) {
    .form-row {
      grid-template-columns: 1fr 1fr;
    }
  }

  .form-section :global(.input-group),
  .form-section :global(.checkbox-group),
  .form-section :global(.radio-group) {
    margin-bottom: var(--space-4);
  }

  .form-error {
    display: flex;
    align-items: center;
    gap: var(--space-2);
    padding: var(--space-3) var(--space-4);
    background-color: rgba(198, 40, 40, 0.1);
    border: 1px solid var(--color-error);
    border-radius: var(--radius-sm);
    color: var(--color-error);
    font-size: var(--text-sm);
    margin-bottom: var(--space-4);
  }

  .form-error[hidden] {
    display: none;
  }

  /* Sidebar */
  .sidebar {
    display: flex;
    flex-direction: column;
    gap: var(--space-6);
  }

  @media (min-width: 1024px) {
    .sidebar {
      position: sticky;
      top: calc(var(--header-height-desktop) + var(--space-6));
      align-self: start;
    }
  }

  .price-card {
    background-color: var(--color-white);
    border-radius: var(--radius-md);
    padding: var(--space-6);
    border: 1px solid var(--color-gray-200);
  }

  .price-card h3 {
    font-size: var(--text-lg);
    margin-bottom: var(--space-4);
  }

  .price-card__event {
    display: flex;
    align-items: center;
    gap: var(--space-3);
    margin-bottom: var(--space-4);
    padding-bottom: var(--space-4);
    border-bottom: 1px solid var(--color-gray-200);
    font-weight: var(--font-semibold);
  }

  .price-card__price {
    display: flex;
    flex-direction: column;
    align-items: center;
    text-align: center;
    margin-bottom: var(--space-4);
    padding-bottom: var(--space-4);
    border-bottom: 1px solid var(--color-gray-200);
  }

  .price-card__amount {
    font-family: var(--font-heading);
    font-size: var(--text-4xl);
    font-weight: var(--font-bold);
    color: var(--color-primary);
  }

  .price-card__label {
    font-size: var(--text-sm);
    color: var(--color-gray-600);
  }

  .price-card__includes {
    list-style: none;
    padding: 0;
    margin: 0;
  }

  .price-card__includes li {
    display: flex;
    align-items: center;
    gap: var(--space-3);
    padding: var(--space-2) 0;
    font-size: var(--text-sm);
    color: var(--color-gray-700);
  }

  .price-card__includes :global(.icon) {
    color: var(--color-primary);
    flex-shrink: 0;
  }

  .info-card {
    background-color: var(--color-off-white);
    border-radius: var(--radius-md);
    padding: var(--space-4);
  }

  .info-card h4 {
    font-size: var(--text-base);
    margin-bottom: var(--space-2);
  }

  .info-card p {
    font-size: var(--text-sm);
    color: var(--color-gray-600);
    margin-bottom: var(--space-3);
  }

  .info-card__link {
    display: flex;
    align-items: center;
    gap: var(--space-2);
    font-size: var(--text-sm);
    font-weight: var(--font-semibold);
    color: var(--color-primary);
    text-decoration: none;
  }

  .info-card__link:hover {
    text-decoration: underline;
  }
</style>

<script define:vars={{ apiUrl }}>
  const form = document.getElementById('registration-form');
  const errorDiv = document.getElementById('form-error');

  if (form && errorDiv) {
    form.addEventListener('submit', async (e) => {
      e.preventDefault();

      const formData = new FormData(form);
      const submitButton = form.querySelector('button[type="submit"]');

      // Disable button during submission
      if (submitButton) {
        submitButton.disabled = true;
        submitButton.textContent = 'Elaborazione...';
      }

      // Hide previous errors
      errorDiv.hidden = true;

      // Prepare data
      const data = {
        nome: formData.get('nome'),
        cognome: formData.get('cognome'),
        email: formData.get('email'),
        telefono: formData.get('telefono'),
        contattoEmergenza: formData.get('contattoEmergenza'),
        telefonoEmergenza: formData.get('telefonoEmergenza'),
        percorso: formData.get('percorso'),
        consensoLista: formData.get('consensoLista') === 'true',
        consensoPrivacy: formData.get('consensoPrivacy') === 'true',
      };

      try {
        const response = await fetch(`${apiUrl}/register`, {
          method: 'POST',
          headers: {
            'Content-Type': 'application/json',
          },
          body: JSON.stringify({
            data,
            successUrl: window.location.origin + '/magna-e-pedala/iscrizioni?success=true',
            cancelUrl: window.location.origin + '/magna-e-pedala/iscrizioni?cancelled=true',
          }),
        });

        const result = await response.json();

        if (response.ok && result.checkoutUrl) {
          // Redirect to Stripe Checkout
          window.location.href = result.checkoutUrl;
        } else {
          // Show error
          const errorSpan = errorDiv.querySelector('span');
          if (errorSpan) {
            if (result.details) {
              // Validation errors
              const firstError = Object.values(result.details).flat()[0];
              errorSpan.textContent = firstError || result.error;
            } else {
              errorSpan.textContent = result.error || 'Si è verificato un errore';
            }
          }
          errorDiv.hidden = false;
          errorDiv.scrollIntoView({ behavior: 'smooth', block: 'center' });
        }
      } catch (error) {
        const errorSpan = errorDiv.querySelector('span');
        if (errorSpan) {
          errorSpan.textContent = 'Errore di connessione. Riprova più tardi.';
        }
        errorDiv.hidden = false;
      } finally {
        // Re-enable button
        if (submitButton) {
          submitButton.disabled = false;
          submitButton.textContent = 'Procedi al pagamento';
        }
      }
    });

    // Check for success/cancelled URL params
    const urlParams = new URLSearchParams(window.location.search);
    if (urlParams.get('success') === 'true') {
      // Show success message (could be a modal or redirect to a success page)
      alert('Grazie per la tua iscrizione! Riceverai una email di conferma.');
      // Clean URL
      window.history.replaceState({}, '', window.location.pathname);
    } else if (urlParams.get('cancelled') === 'true') {
      const errorSpan = errorDiv.querySelector('span');
      if (errorSpan) {
        errorSpan.textContent = 'Pagamento annullato. Puoi riprovare quando vuoi.';
      }
      errorDiv.hidden = false;
      window.history.replaceState({}, '', window.location.pathname);
    }
  }
</script>
