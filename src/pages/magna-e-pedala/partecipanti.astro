---
import BaseLayout from '../../layouts/BaseLayout.astro';
import PageHeader from '../../components/layout/PageHeader.astro';
import Button from '../../components/ui/Button.astro';
import Input from '../../components/ui/Input.astro';
import Badge from '../../components/ui/Badge.astro';
import Icon from '../../components/ui/Icon.astro';

const apiUrl = import.meta.env.PUBLIC_API_URL || 'https://api.estebike.it';

const routeLabels: Record<string, string> = {
  lungo: 'Lungo',
  medio: 'Medio',
  corto: 'Corto',
};

const routeColors: Record<string, 'error' | 'warning' | 'success'> = {
  lungo: 'error',
  medio: 'warning',
  corto: 'success',
};
---

<BaseLayout
  title="Partecipanti"
  description="Scopri chi si è iscritto al Magna & Pedala 2026. Lista dei partecipanti aggiornata in tempo reale."
>
  <PageHeader
    title="Partecipanti"
    subtitle="Magna & Pedala 2026"
    breadcrumbs={[
      { label: 'Magna & Pedala', href: '/magna-e-pedala' },
      { label: 'Partecipanti' },
    ]}
  />

  <section class="section">
    <div class="container">
      <!-- Stats Banner -->
      <div class="stats-banner" id="stats-banner">
        <div class="stats-banner__total">
          <span class="stats-banner__number" id="total-count">-</span>
          <span class="stats-banner__label">Iscritti totali</span>
        </div>
        <div class="stats-banner__routes">
          <div class="stats-banner__route">
            <Badge variant="error" size="sm">Lungo</Badge>
            <span id="lungo-count">-</span>
          </div>
          <div class="stats-banner__route">
            <Badge variant="warning" size="sm">Medio</Badge>
            <span id="medio-count">-</span>
          </div>
          <div class="stats-banner__route">
            <Badge variant="success" size="sm">Corto</Badge>
            <span id="corto-count">-</span>
          </div>
        </div>
      </div>

      <!-- Search -->
      <div class="search-bar">
        <Input
          type="text"
          name="search"
          id="search-input"
          label=""
          placeholder="Cerca per nome..."
        />
      </div>

      <!-- Participants List -->
      <div class="participants-container">
        <div class="loading" id="loading">
          <div class="loading__spinner"></div>
          <p>Caricamento partecipanti...</p>
        </div>

        <div class="error" id="error" hidden>
          <Icon name="x" size={24} />
          <p>Impossibile caricare la lista dei partecipanti.</p>
          <Button id="retry-button" variant="secondary" size="sm">
            Riprova
          </Button>
        </div>

        <div class="participants-list" id="participants-list" hidden>
          <table class="participants-table">
            <thead>
              <tr>
                <th>Nome</th>
                <th>Percorso</th>
              </tr>
            </thead>
            <tbody id="participants-body">
              <!-- Populated by JavaScript -->
            </tbody>
          </table>

          <p class="participants-empty" id="empty-message" hidden>
            Nessun partecipante trovato.
          </p>
        </div>
      </div>

      <!-- Privacy Note -->
      <div class="privacy-note">
        <Icon name="users" size={18} />
        <p>
          Questa lista mostra solo i partecipanti che hanno acconsentito alla
          pubblicazione del proprio nome. Il conteggio totale include tutti gli
          iscritti.
        </p>
      </div>

      <!-- CTA -->
      <div class="cta-section">
        <p>Non sei ancora iscritto?</p>
        <Button href="/magna-e-pedala/iscrizioni" variant="primary">
          Iscriviti ora
        </Button>
      </div>
    </div>
  </section>
</BaseLayout>

<style>
  /* Stats Banner */
  .stats-banner {
    display: flex;
    flex-direction: column;
    gap: var(--space-4);
    padding: var(--space-6);
    background: linear-gradient(135deg, var(--color-primary) 0%, var(--color-primary-dark) 100%);
    border-radius: var(--radius-md);
    color: var(--color-white);
    margin-bottom: var(--space-6);
  }

  @media (min-width: 768px) {
    .stats-banner {
      flex-direction: row;
      align-items: center;
      justify-content: space-between;
    }
  }

  .stats-banner__total {
    display: flex;
    flex-direction: column;
    align-items: center;
    text-align: center;
  }

  @media (min-width: 768px) {
    .stats-banner__total {
      align-items: flex-start;
      text-align: left;
    }
  }

  .stats-banner__number {
    font-family: var(--font-heading);
    font-size: var(--text-5xl);
    font-weight: var(--font-bold);
    line-height: 1;
  }

  .stats-banner__label {
    font-size: var(--text-sm);
    opacity: 0.9;
    text-transform: uppercase;
    letter-spacing: 0.05em;
  }

  .stats-banner__routes {
    display: flex;
    gap: var(--space-4);
    justify-content: center;
  }

  .stats-banner__route {
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: var(--space-1);
  }

  .stats-banner__route span:last-child {
    font-family: var(--font-heading);
    font-size: var(--text-xl);
    font-weight: var(--font-bold);
  }

  /* Search Bar */
  .search-bar {
    margin-bottom: var(--space-6);
    max-width: 400px;
  }

  .search-bar :global(.input-group) {
    margin-bottom: 0;
  }

  /* Participants Container */
  .participants-container {
    background-color: var(--color-white);
    border-radius: var(--radius-md);
    border: 1px solid var(--color-gray-200);
    min-height: 300px;
    overflow: hidden;
  }

  /* Loading State */
  .loading {
    display: flex;
    flex-direction: column;
    align-items: center;
    justify-content: center;
    padding: var(--space-12);
    gap: var(--space-4);
  }

  .loading__spinner {
    width: 40px;
    height: 40px;
    border: 3px solid var(--color-gray-200);
    border-top-color: var(--color-primary);
    border-radius: 50%;
    animation: spin 1s linear infinite;
  }

  @keyframes spin {
    to { transform: rotate(360deg); }
  }

  .loading p {
    color: var(--color-gray-600);
    margin: 0;
  }

  /* Error State */
  .error {
    display: flex;
    flex-direction: column;
    align-items: center;
    justify-content: center;
    padding: var(--space-12);
    gap: var(--space-4);
    text-align: center;
  }

  .error :global(.icon) {
    color: var(--color-error);
  }

  .error p {
    color: var(--color-gray-600);
    margin: 0;
  }

  .error[hidden] {
    display: none;
  }

  /* Participants List */
  .participants-list[hidden] {
    display: none;
  }

  .participants-table {
    width: 100%;
    border-collapse: collapse;
  }

  .participants-table th,
  .participants-table td {
    padding: var(--space-3) var(--space-4);
    text-align: left;
    border-bottom: 1px solid var(--color-gray-200);
  }

  .participants-table th {
    font-family: var(--font-heading);
    font-size: var(--text-sm);
    font-weight: var(--font-semibold);
    text-transform: uppercase;
    letter-spacing: 0.05em;
    color: var(--color-gray-600);
    background-color: var(--color-off-white);
  }

  .participants-table td {
    font-size: var(--text-base);
  }

  .participants-table tbody tr:hover {
    background-color: var(--color-off-white);
  }

  .participants-table tbody tr:last-child td {
    border-bottom: none;
  }

  .participants-empty {
    text-align: center;
    padding: var(--space-8);
    color: var(--color-gray-600);
    margin: 0;
  }

  .participants-empty[hidden] {
    display: none;
  }

  /* Privacy Note */
  .privacy-note {
    display: flex;
    align-items: flex-start;
    gap: var(--space-3);
    margin-top: var(--space-6);
    padding: var(--space-4);
    background-color: var(--color-off-white);
    border-radius: var(--radius-md);
  }

  .privacy-note :global(.icon) {
    color: var(--color-gray-600);
    flex-shrink: 0;
    margin-top: 2px;
  }

  .privacy-note p {
    font-size: var(--text-sm);
    color: var(--color-gray-600);
    line-height: var(--leading-relaxed);
    margin: 0;
  }

  /* CTA */
  .cta-section {
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: var(--space-3);
    margin-top: var(--space-10);
    padding-top: var(--space-8);
    border-top: 1px solid var(--color-gray-200);
  }

  @media (min-width: 640px) {
    .cta-section {
      flex-direction: row;
      justify-content: center;
    }
  }

  .cta-section p {
    margin: 0;
    color: var(--color-gray-600);
  }
</style>

<script define:vars={{ apiUrl, routeLabels, routeColors }}>
  const loadingEl = document.getElementById('loading');
  const errorEl = document.getElementById('error');
  const participantsEl = document.getElementById('participants-list');
  const participantsBody = document.getElementById('participants-body');
  const emptyMessage = document.getElementById('empty-message');
  const searchInput = document.getElementById('search-input');
  const retryButton = document.getElementById('retry-button');

  // Stats elements
  const totalCount = document.getElementById('total-count');
  const lungoCount = document.getElementById('lungo-count');
  const medioCount = document.getElementById('medio-count');
  const cortoCount = document.getElementById('corto-count');

  let allParticipants = [];

  async function loadParticipants() {
    loadingEl.style.display = 'flex';
    errorEl.hidden = true;
    participantsEl.hidden = true;

    try {
      const response = await fetch(`${apiUrl}/participants`);

      if (!response.ok) {
        throw new Error('Failed to fetch');
      }

      const data = await response.json();

      // Update stats
      totalCount.textContent = data.total;
      lungoCount.textContent = data.stats.lungo;
      medioCount.textContent = data.stats.medio;
      cortoCount.textContent = data.stats.corto;

      // Store participants for filtering
      allParticipants = data.participants;

      // Render participants
      renderParticipants(allParticipants);

      loadingEl.style.display = 'none';
      participantsEl.hidden = false;
    } catch (error) {
      console.error('Error loading participants:', error);
      loadingEl.style.display = 'none';
      errorEl.hidden = false;
    }
  }

  function renderParticipants(participants) {
    if (participants.length === 0) {
      participantsBody.innerHTML = '';
      emptyMessage.hidden = false;
      return;
    }

    emptyMessage.hidden = true;

    participantsBody.innerHTML = participants.map((p) => {
      const badgeVariant = routeColors[p.percorso] || 'neutral';
      const routeLabel = routeLabels[p.percorso] || p.percorso;

      return `
        <tr>
          <td>${escapeHtml(p.nome)} ${escapeHtml(p.cognome)}</td>
          <td>
            <span class="badge badge--${badgeVariant} badge--sm">${routeLabel}</span>
          </td>
        </tr>
      `;
    }).join('');
  }

  function escapeHtml(text) {
    const div = document.createElement('div');
    div.textContent = text;
    return div.innerHTML;
  }

  // Search functionality
  searchInput?.addEventListener('input', (e) => {
    const query = e.target.value.toLowerCase().trim();

    if (!query) {
      renderParticipants(allParticipants);
      return;
    }

    const filtered = allParticipants.filter((p) =>
      `${p.nome} ${p.cognome}`.toLowerCase().includes(query)
    );

    renderParticipants(filtered);
  });

  // Retry button
  retryButton?.addEventListener('click', loadParticipants);

  // Initial load
  loadParticipants();
</script>
